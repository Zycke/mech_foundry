<div class="item-sheet-content">
  <header class="sheet-header">
    <img class="profile-img" src="{{item.img}}" data-action="editImage" data-edit="img" title="{{item.name}}" height="50" width="50" />
    <div class="header-fields">
      <h1>
        <input name="name" type="text" value="{{item.name}}" placeholder="Supply Name" />
      </h1>
    </div>
  </header>

  <section class="sheet-body">
    <div class="tab-content">
      <div class="form-group-grid supplies-fields">
        <div class="form-group">
          <label>Supply Type</label>
          <input type="text" name="system.supplyType" value="{{system.supplyType}}" placeholder="e.g., Tools, Survival, Espionage" />
        </div>
        <div class="form-group">
          <label>Equipment Rating</label>
          <input type="text" name="system.equipmentRating" value="{{system.equipmentRating}}" placeholder="e.g., C/A-B-A/C" />
        </div>
        <div class="form-group">
          <label>Cost (C-bills)</label>
          <input type="number" name="system.cost" value="{{system.cost}}" min="0" />
        </div>
        <div class="form-group">
          <label>Quantity</label>
          <input type="number" name="system.quantity" value="{{system.quantity}}" min="0" />
        </div>
        <div class="form-group">
          <label>Mass (kg)</label>
          <input type="number" name="system.mass" value="{{system.mass}}" min="0" step="0.01" />
        </div>
        <div class="form-group">
          <label>Power Use</label>
          <input type="number" name="system.powerUse" value="{{system.powerUse}}" min="0" step="0.1" />
        </div>
        <div class="form-group">
          <label>Affiliation</label>
          <input type="text" name="system.affiliation" value="{{system.affiliation}}" placeholder="e.g., LA, CS" />
        </div>
      </div>

      <div class="form-group full-width">
        <label>Notes</label>
        <input type="text" name="system.notes" value="{{system.notes}}" />
      </div>

      {{!-- Description --}}
      <h3>Description</h3>
      <div class="description-field">
        {{#if editable}}
        <prose-mirror name="system.description" data-document-uuid="{{item.uuid}}" value="{{system.description}}" collaborate="false" toggled="true">{{{enrichedDescription}}}</prose-mirror>
        {{else}}{{{enrichedDescription}}}{{/if}}
      </div>
    </div>
  </section>
</div>
