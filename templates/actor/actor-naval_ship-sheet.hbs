<div class="naval-ship-content actor-sheet-content">

  {{!-- Header --}}
  <header class="sheet-header ship-header">
    <img class="profile-img" src="{{actor.img}}" data-action="editImage" data-edit="img" title="{{actor.name}}" height="70" width="70" />
    <div class="header-fields">
      <h1><input name="name" type="text" value="{{actor.name}}" placeholder="Vessel Name" /></h1>
      <div class="ship-idfields">
        <label>Class <input type="text" name="system.vessel.class" value="{{system.vessel.class}}" placeholder="e.g. Union" /></label>
        <label>Role <input type="text" name="system.vessel.role" value="{{system.vessel.role}}" placeholder="e.g. Assault Transport" /></label>
      </div>
    </div>
  </header>

  {{!-- Tabs --}}
  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="vessel">Vessel</a>
    <a class="item" data-tab="weapons">Weapons</a>
    <a class="item" data-tab="bays">Bays</a>
    <a class="item" data-tab="logistics">Logistics</a>
    <a class="item" data-tab="crew">Crew &amp; Departments</a>
    <a class="item" data-tab="notes">Notes</a>
  </nav>

  <section class="sheet-body">

    {{!-- ==================== VESSEL TAB ==================== --}}
    <div class="tab" data-tab="vessel" data-group="primary">
      <div class="tab-content">

        {{!-- Armor arcs --}}
        <div class="items-header"><h3>Armor</h3></div>
        <div class="ship-armor-grid">
          {{#each arcFields}}
          <div class="armor-arc">
            <span class="arc-label">{{this.label}}</span>
            <div class="arc-inputs">
              <input type="number" min="0" name="system.armor.{{this.key}}.value" value="{{lookup (lookup ../system.armor this.key) 'value'}}" title="Current" {{#unless ../editable}}disabled{{/unless}} />
              <span class="arc-sep">/</span>
              <input type="number" min="0" name="system.armor.{{this.key}}.max" value="{{lookup (lookup ../system.armor this.key) 'max'}}" title="Max" {{#unless ../editable}}disabled{{/unless}} />
            </div>
          </div>
          {{/each}}
        </div>

        {{!-- Movement / vital stats — stacked pairs per column --}}
        <div class="items-header"><h3>Movement &amp; Vitals</h3></div>
        <div class="ship-stats-cols">
          {{#each movementColumns}}
          <div class="ship-stats-col">
            {{#each this}}
            <div class="ship-stat">
              <label>{{this.label}}</label>
              <input type="number" name="system.movement.{{this.key}}" value="{{lookup ../../system.movement this.key}}" {{#unless ../../editable}}disabled{{/unless}} />
            </div>
            {{/each}}
          </div>
          {{/each}}
        </div>

        {{!-- Turn track --}}
        <div class="items-header"><h3>Turn Record</h3></div>
        <div class="track-scroll">
          <table class="ship-track">
            <thead>
              <tr><th>Turn</th>{{#each trackTurns}}<th>{{this.num}}</th>{{/each}}</tr>
            </thead>
            <tbody>
              <tr>
                <td class="track-label">Thrust</td>
                {{#each trackTurns}}
                <td><input type="number" name="system.track.{{this.key}}.thrust" value="{{lookup (lookup ../system.track this.key) 'thrust'}}" {{#unless ../editable}}disabled{{/unless}} /></td>
                {{/each}}
              </tr>
              <tr>
                <td class="track-label">Velocity</td>
                {{#each trackTurns}}
                <td><input type="number" name="system.track.{{this.key}}.velocity" value="{{lookup (lookup ../system.track this.key) 'velocity'}}" {{#unless ../editable}}disabled{{/unless}} /></td>
                {{/each}}
              </tr>
            </tbody>
          </table>
        </div>

        {{!-- Critical-hit reference --}}
        <div class="items-header"><h3>Critical Hit Reference</h3></div>
        <div class="crit-legend">Die #1: 1–3 selects the left set, 4–6 the right; Die #2 (1–6) selects the column below.</div>
        <div class="track-scroll">
          <table class="ship-crit">
            <thead>
              <tr><th>Die #2 →</th><th>1</th><th>2</th><th>3</th><th>4</th><th>5</th><th>6</th></tr>
            </thead>
            <tbody>
              {{#each critTable}}
              <tr>
                <td class="crit-row-label">Row {{add @index 1}}</td>
                {{#each this}}<td>{{this}}</td>{{/each}}
              </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      </div>
    </div>

    {{!-- ==================== WEAPONS TAB ==================== --}}
    <div class="tab" data-tab="weapons" data-group="primary">
      <div class="tab-content">
        <div class="items-header weapons-bar">
          <h3>Weapon Bays</h3>
          {{#if editable}}<button type="button" class="add-weapon"><i class="fas fa-plus"></i> Add Weapon</button>{{/if}}
        </div>
        <div class="track-scroll">
          <table class="ship-weapons">
            <thead>
              <tr>
                <th class="w-name">Weapons</th>
                {{#each weaponColumns}}<th>{{this.label}}</th>{{/each}}
                {{#if editable}}<th></th>{{/if}}
              </tr>
            </thead>
            <tbody>
              {{#each weapons}}
              <tr>
                <td class="w-name"><input type="text" class="weapon-field" data-weapon-id="{{this.id}}" data-field="name" value="{{this.name}}" placeholder="Weapon" {{#unless ../editable}}disabled{{/unless}} /></td>
                {{#each ../weaponColumns}}
                <td><input type="text" class="weapon-field" data-weapon-id="{{../id}}" data-field="{{this.key}}" value="{{lookup .. this.key}}" {{#unless ../../editable}}disabled{{/unless}} /></td>
                {{/each}}
                {{#if ../editable}}<td><a class="remove-weapon" data-weapon-id="{{this.id}}" title="Remove"><i class="fas fa-trash"></i></a></td>{{/if}}
              </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
        {{#unless weapons.length}}<p class="empty-notice">No weapons. Click "Add Weapon".</p>{{/unless}}
      </div>
    </div>

    {{!-- ==================== BAYS TAB ==================== --}}
    <div class="tab" data-tab="bays" data-group="primary">
      <div class="tab-content">
        <div class="items-header weapons-bar">
          <h3>Bays &amp; Cubicles</h3>
          {{#if editable}}<button type="button" class="add-bay"><i class="fas fa-plus"></i> Add Bay</button>{{/if}}
        </div>
        <div class="cargo-readout">
          <span>Cargo capacity: <strong>{{cargoCapacity}}</strong> t</span>
          <span>Used: <strong>{{cargoUsed}}</strong> t</span>
          <span>Free: <strong>{{cargoFree}}</strong> t</span>
          <span class="logi-note">Supplies (1 t each) are managed from the company Logistics tab.</span>
        </div>

        {{#each bays}}
        <div class="bay-panel" data-bay-id="{{this.id}}">
          <div class="bay-panel-head">
            <input type="text" class="bay-name" data-bay-id="{{this.id}}" value="{{this.name}}" placeholder="Bay name" {{#unless ../editable}}disabled{{/unless}} />
            <span class="bay-count">{{this.components.length}} slot{{#unless (eq this.components.length 1)}}s{{/unless}}</span>
            {{#if ../editable}}
            <select class="add-component" data-bay-id="{{this.id}}" title="Add a cubicle or cargo hold">
              <option value="">+ Add…</option>
              {{#each ../bayComponentTypes}}<option value="{{this.key}}">{{this.label}}</option>{{/each}}
            </select>
            <a class="remove-bay" data-bay-id="{{this.id}}" title="Remove Bay"><i class="fas fa-trash"></i></a>
            {{/if}}
          </div>

          {{#if this.components.length}}
          <table class="bay-table">
            <tbody>
              {{#each this.components}}
              <tr>
                <td class="bt-type">{{this.label}}</td>
                <td class="bt-contents">
                  {{#if this.assignable}}
                    {{#if this.mtoe}}
                    <a class="component-open" data-actor-id="{{this.mtoe.actorId}}">{{this.mtoe.name}}</a>
                    <span class="comp-mtoe-unit">({{this.mtoe.unitName}})</span>
                    <span class="comp-mtoe-status vstatus-{{this.mtoe.status}}">{{this.mtoe.status}}</span>
                    {{else}}
                    <select class="component-unit" data-bay-id="{{../id}}" data-component-id="{{this.id}}" {{#unless ../../editable}}disabled{{/unless}}>
                      <option value="">— empty —</option>
                      {{#each this.options}}<option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.name}}</option>{{/each}}
                    </select>
                    {{#if this.assignedExists}}<a class="component-open" data-actor-id="{{this.unitId}}" title="Open sheet"><i class="fas fa-up-right-from-square"></i></a>{{/if}}
                    {{/if}}
                  {{/if}}
                  {{#if this.hasSquadSize}}<span class="bt-inline">Squad <input type="number" min="0" class="component-squad" data-bay-id="{{../id}}" data-component-id="{{this.id}}" data-field="squadSize" value="{{this.squadSize}}" {{#unless ../../editable}}disabled{{/unless}} /></span>{{/if}}
                  {{#if this.hasTonnage}}<span class="bt-inline">Tonnage <input type="number" min="0" class="component-tonnage" data-bay-id="{{../id}}" data-component-id="{{this.id}}" data-field="tonnage" value="{{this.tonnage}}" {{#unless ../../editable}}disabled{{/unless}} /></span>{{/if}}
                </td>
                <td class="bt-remove">{{#if ../../editable}}<a class="remove-component" data-bay-id="{{../id}}" data-component-id="{{this.id}}" title="Remove"><i class="fas fa-times"></i></a>{{/if}}</td>
              </tr>
              {{/each}}
            </tbody>
          </table>
          {{else}}
          <p class="empty-notice small">Empty bay. Use “+ Add…” to add a cubicle or cargo hold.</p>
          {{/if}}
        </div>
        {{/each}}
        {{#unless bays.length}}<p class="empty-notice">No bays. Click "Add Bay" to create one.</p>{{/unless}}
      </div>
    </div>

    {{!-- ==================== LOGISTICS TAB (read-only) ==================== --}}
    <div class="tab" data-tab="logistics" data-group="primary">
      <div class="tab-content">
        <div class="cargo-readout">
          <span>Cargo capacity: <strong>{{cargoCapacity}}</strong> t</span>
          <span>Used: <strong>{{cargoUsed}}</strong> t</span>
          <span>Free: <strong>{{cargoFree}}</strong> t</span>
          <span class="logi-note">Read-only — supplies are managed from the owning company's Logistics tab.</span>
        </div>

        <div class="items-header"><h3>Ship Supplies</h3></div>
        <div class="ship-manifest">
          {{#each logiShip}}
          <div class="manifest-cell"><span class="mf-label">{{this.label}}</span><span class="mf-val">{{this.value}}</span></div>
          {{/each}}
        </div>
        {{#if logiShipAmmo.length}}
        <div class="manifest-ammo">
          {{#each logiShipAmmo}}<span class="ammo-chip">{{this.name}} <strong>{{this.value}}</strong></span>{{/each}}
        </div>
        {{/if}}

        <div class="items-header"><h3>Ground Forces Supplies</h3></div>
        {{#each logiGround}}
        <div class="manifest-group">
          <span class="manifest-group-title">{{this.label}}</span>
          <div class="ship-manifest">
            {{#each this.fields}}
            <div class="manifest-cell"><span class="mf-label">{{this.label}}</span><span class="mf-val">{{this.value}}</span></div>
            {{/each}}
          </div>
        </div>
        {{/each}}
        {{#if logiGroundAmmo.length}}
        <div class="manifest-ammo">
          {{#each logiGroundAmmo}}<span class="ammo-chip">{{this.name}}{{#if this.usedBy}} <em>({{this.usedBy}})</em>{{/if}} <strong>{{this.value}}</strong></span>{{/each}}
        </div>
        {{/if}}
      </div>
    </div>

    {{!-- ==================== CREW & DEPARTMENTS TAB ==================== --}}
    <div class="tab" data-tab="crew" data-group="primary">
      <div class="tab-content">
        <div class="items-header weapons-bar">
          <h3>Departments &amp; Crew Requirements</h3>
          {{#if editable}}<button type="button" class="add-ship-dept"><i class="fas fa-plus"></i> Add Department</button>{{/if}}
        </div>
        <p class="logi-note">Define this vessel's departments and how many crew each needs. Crew are assigned to these departments from the owning company's Locations tab.</p>

        <table class="ship-depts">
          <thead>
            <tr><th>Department</th><th>Primary Crew</th><th>Req. Primary</th><th>Req. Officers</th>{{#if editable}}<th></th>{{/if}}</tr>
          </thead>
          <tbody>
            {{#each departments}}
            <tr>
              <td>
                <select class="ship-dept-type" data-dept-id="{{this.id}}" {{#unless ../editable}}disabled{{/unless}}>
                  {{#each ../departmentTypes}}
                  <option value="{{this.key}}" {{#if (eq this.key ../type)}}selected{{/if}}>{{this.label}}</option>
                  {{/each}}
                </select>
              </td>
              <td class="dept-primary">{{this.primaryLabel}}</td>
              <td><input type="number" min="0" class="ship-dept-req" data-dept-id="{{this.id}}" data-field="requiredPrimary" value="{{this.requiredPrimary}}" {{#unless ../editable}}disabled{{/unless}} /></td>
              <td><input type="number" min="0" class="ship-dept-req" data-dept-id="{{this.id}}" data-field="requiredOfficers" value="{{this.requiredOfficers}}" {{#unless ../editable}}disabled{{/unless}} /></td>
              {{#if ../editable}}<td><a class="remove-ship-dept" data-dept-id="{{this.id}}" title="Remove"><i class="fas fa-trash"></i></a></td>{{/if}}
            </tr>
            {{/each}}
            {{#if departments.length}}
            <tr class="dept-total-row">
              <td>Total</td><td></td><td>{{totalReqPrimary}}</td><td>{{totalReqOfficers}}</td>{{#if editable}}<td></td>{{/if}}
            </tr>
            {{/if}}
          </tbody>
        </table>
        {{#unless departments.length}}<p class="empty-notice">No departments defined. Click "Add Department".</p>{{/unless}}
      </div>
    </div>

    {{!-- ==================== NOTES TAB ==================== --}}
    <div class="tab" data-tab="notes" data-group="primary">
      <div class="tab-content">
        <div class="editor-container">
          {{#if editable}}
          <prose-mirror name="system.biography" data-document-uuid="{{actor.uuid}}" value="{{system.biography}}" collaborate="false" toggled="true">{{{enrichedBiography}}}</prose-mirror>
          {{else}}{{{enrichedBiography}}}{{/if}}
        </div>
      </div>
    </div>

  </section>
</div>
