<div class="company-sheet-content actor-sheet-content">

  {{!-- Company Header --}}
  <header class="sheet-header company-header">
    <img class="profile-img" src="{{actor.img}}" data-action="editImage" data-edit="img" title="{{actor.name}}" height="70" width="70" />
    <div class="header-fields">
      <h1 class="company-name">
        <input name="name" type="text" value="{{actor.name}}" placeholder="Company Name" />
      </h1>
      <div class="company-summary">
        <div class="summary-field cbills-field">
          <label>C-Bills</label>
          <div class="cbills-display">
            <span class="cbills-value computed-value">{{numberFormat system.cbills}}</span>
            {{#if editable}}
            <div class="cbills-controls">
              <button type="button" class="cbills-add" title="Add Funds"><i class="fas fa-plus"></i></button>
              <button type="button" class="cbills-remove" title="Remove Funds"><i class="fas fa-minus"></i></button>
            </div>
            {{/if}}
          </div>
        </div>
        <div class="summary-field">
          <label>Personnel</label>
          <span class="computed-value">{{totalPersonnel}}</span>
        </div>
        <div class="summary-field">
          <label>Locations</label>
          <span class="computed-value">{{locationCount}}</span>
        </div>
        <div class="summary-field">
          <label>Reputation</label>
          <input type="text" name="system.reputation" value="{{system.reputation}}" class="reputation-input" />
        </div>
      </div>
    </div>
  </header>

  {{!-- Tab Navigation --}}
  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="locations">Locations</a>
    <a class="item" data-tab="logistics">Logistics</a>
    <a class="item" data-tab="status">Status</a>
    <a class="item" data-tab="mtoe">MTOE</a>
    <a class="item" data-tab="assets">Assets</a>
    <a class="item" data-tab="finances">Finances</a>
  </nav>

  {{!-- Sheet Body --}}
  <section class="sheet-body">

    {{!-- ==================== LOCATIONS TAB ==================== --}}
    <div class="tab" data-tab="locations" data-group="primary">
      <div class="tab-content">

        {{!-- Company-wide crew availability strip --}}
        <div class="pool-strip">
          {{#each crewPools}}
          <div class="pool-chip {{#if this.over}}over{{/if}}">
            <span class="pool-label">{{this.label}}</span>
            <span class="pool-count"><strong>{{this.available}}</strong> free / {{this.total}}</span>
          </div>
          {{/each}}
          <span class="pool-hint">Set totals on the Status tab</span>
        </div>

        <p class="drop-hint"><i class="fas fa-anchor"></i> Drag a Naval Ship or Installation actor here to add it as a location.</p>

        {{#each locations}}
        <div class="location-card" data-loc-id="{{this.id}}">
          <div class="location-head">
            <img src="{{this.img}}" width="40" height="40" />
            <div class="location-title">
              <span class="location-name">{{this.name}}</span>
              <span class="location-type">{{this.typeLabel}}{{#unless this.exists}} — actor deleted{{/unless}}</span>
            </div>
            <div class="location-status-field">
              <label>Status</label>
              <input type="text" class="location-status" data-loc-id="{{this.id}}" value="{{this.status}}" placeholder="e.g. On station" {{#unless ../editable}}disabled{{/unless}} />
            </div>
            <span class="location-crew-total"><i class="fas fa-users"></i> {{this.crewAssignedTotal}} crew</span>
            {{#if ../editable}}
            <a class="location-remove" data-loc-id="{{this.id}}" title="Remove Location"><i class="fas fa-times"></i></a>
            {{/if}}
          </div>

          <div class="location-body">
            <div class="dept-block-header">
              <span><i class="fas fa-sitemap"></i> Departments</span>
              {{#if ../editable}}
              <button type="button" class="add-department" data-loc-id="{{this.id}}"><i class="fas fa-plus"></i> Add Department</button>
              {{/if}}
            </div>

            {{#each this.departments}}
            <div class="dept-row {{#if this.understaffed}}understaffed{{/if}}">
              <input type="text" class="dept-name" data-loc-id="{{../id}}" data-dept-id="{{this.id}}" value="{{this.name}}" placeholder="Department" {{#unless ../../editable}}disabled{{/unless}} />
              <div class="dept-crew-grid">
                {{#each this.crew}}
                <div class="dept-crew-cell">
                  <span class="dept-crew-label">{{this.label}}</span>
                  <span class="dept-crew-inputs">
                    <input type="number" class="dept-crew" min="0"
                           data-loc-id="{{../../id}}" data-dept-id="{{../id}}" data-group="assigned" data-type="{{this.key}}"
                           value="{{this.assigned}}" title="Assigned" {{#unless ../../../editable}}disabled{{/unless}} />
                    <span class="dept-crew-sep">/</span>
                    <input type="number" class="dept-crew req" min="0"
                           data-loc-id="{{../../id}}" data-dept-id="{{../id}}" data-group="required" data-type="{{this.key}}"
                           value="{{this.required}}" title="Required" {{#unless ../../../editable}}disabled{{/unless}} />
                  </span>
                </div>
                {{/each}}
                <span class="dept-fill {{#if this.understaffed}}short{{/if}}">{{this.assignedTotal}}/{{this.reqTotal}}</span>
                {{#if ../../editable}}
                <a class="remove-department" data-loc-id="{{../id}}" data-dept-id="{{this.id}}" title="Remove Department"><i class="fas fa-trash"></i></a>
                {{/if}}
              </div>
            </div>
            {{/each}}
            {{#unless this.departments.length}}
            <p class="empty-notice small">No departments yet. Add one to staff this location.</p>
            {{/unless}}
          </div>
        </div>
        {{/each}}

        {{#unless locations.length}}
        <p class="empty-notice">No locations. Drag a Naval Ship or Installation actor here.</p>
        {{/unless}}
      </div>
    </div>

    {{!-- ==================== LOGISTICS TAB ==================== --}}
    <div class="tab" data-tab="logistics" data-group="primary">
      <div class="tab-content">

        {{!-- Ship Supplies (per location) --}}
        <div class="logi-section">
          <h3><i class="fas fa-ship"></i> Ship Supplies</h3>
          {{#each shipLocations}}
          <div class="logi-location" data-loc-id="{{this.id}}">
            <div class="logi-location-head">
              <img src="{{this.img}}" width="24" height="24" />
              <span class="location-name">{{this.name}}</span>
              <span class="location-type">{{this.typeLabel}}</span>
            </div>
            <div class="supply-grid">
              {{#each this.supplies}}
              <div class="supply-cell">
                <label>{{this.label}}</label>
                <input type="number" class="ship-supply" min="0" data-loc-id="{{../id}}" data-key="{{this.key}}" value="{{this.value}}" {{#unless ../../editable}}disabled{{/unless}} />
              </div>
              {{/each}}
            </div>
            <div class="ammo-block">
              <div class="ammo-block-head">
                <span><i class="fas fa-box"></i> Ammo Types</span>
                {{#if ../editable}}
                <button type="button" class="add-ship-ammo" data-loc-id="{{this.id}}"><i class="fas fa-plus"></i> Add Ammo</button>
                {{/if}}
              </div>
              {{#each this.ammo}}
              <div class="ammo-row">
                <input type="text" class="ship-ammo-field" data-loc-id="{{../id}}" data-ammo-id="{{this.id}}" data-field="name" value="{{this.name}}" placeholder="Ammo type" {{#unless ../../editable}}disabled{{/unless}} />
                <input type="number" class="ship-ammo-field" min="0" data-loc-id="{{../id}}" data-ammo-id="{{this.id}}" data-field="value" value="{{this.value}}" placeholder="Qty" {{#unless ../../editable}}disabled{{/unless}} />
                {{#if ../../editable}}
                <a class="remove-ship-ammo" data-loc-id="{{../id}}" data-ammo-id="{{this.id}}" title="Remove"><i class="fas fa-times"></i></a>
                {{/if}}
              </div>
              {{/each}}
              <p class="logi-note">Auto-population of needed ammo types from ship sheets will be wired once those sheets carry weapon data.</p>
            </div>
          </div>
          {{/each}}
          {{#unless shipLocations.length}}
          <p class="empty-notice">Add ship / installation locations first (Locations tab).</p>
          {{/unless}}
        </div>

        {{!-- Ground Forces Supplies (company-wide) --}}
        <div class="logi-section">
          <h3><i class="fas fa-truck-field"></i> Ground Forces Supplies</h3>
          <p class="logi-note">Stored in ship cargo, used by deployed troops.</p>
          {{#each groundSupplyGroups}}
          <div class="ground-group">
            <h4 class="category-title">{{this.label}}</h4>
            <div class="supply-grid">
              {{#each this.fields}}
              <div class="supply-cell">
                <label>{{this.label}}</label>
                <input type="number" min="0" name="system.groundSupplies.{{this.key}}" value="{{lookup ../../system.groundSupplies this.key}}" {{#unless ../../editable}}disabled{{/unless}} />
              </div>
              {{/each}}
            </div>
          </div>
          {{/each}}

          <div class="ammo-block">
            <div class="ammo-block-head">
              <span><i class="fas fa-box"></i> Ammo Types</span>
              {{#if editable}}
              <button type="button" class="add-ground-ammo"><i class="fas fa-plus"></i> Add Ammo</button>
              {{/if}}
            </div>
            {{#each system.groundSupplies.ammo}}
            <div class="ammo-row wide">
              <input type="text" class="ground-ammo-field" data-ammo-id="{{this.id}}" data-field="name" value="{{this.name}}" placeholder="Ammo type" {{#unless ../editable}}disabled{{/unless}} />
              <input type="text" class="ground-ammo-field" data-ammo-id="{{this.id}}" data-field="usedBy" value="{{this.usedBy}}" placeholder="Used by (unit)" {{#unless ../editable}}disabled{{/unless}} />
              <input type="number" class="ground-ammo-field" min="0" data-ammo-id="{{this.id}}" data-field="value" value="{{this.value}}" placeholder="Qty" {{#unless ../editable}}disabled{{/unless}} />
              {{#if ../editable}}
              <a class="remove-ground-ammo" data-ammo-id="{{this.id}}" title="Remove"><i class="fas fa-times"></i></a>
              {{/if}}
            </div>
            {{/each}}
            <p class="logi-note">Auto-summing ammo needs from assigned units will be wired once unit sheets carry weapon data.</p>
          </div>
        </div>
      </div>
    </div>

    {{!-- ==================== STATUS TAB ==================== --}}
    <div class="tab" data-tab="status" data-group="primary">
      <div class="tab-content">
        <div class="status-section">
          <h3>Company Status</h3>
          <div class="status-overview">
            <div class="status-item">
              <label>Total Personnel</label>
              <span>{{totalPersonnel}}</span>
            </div>
            <div class="status-item">
              <label>Locations</label>
              <span>{{locationCount}}</span>
            </div>
            <div class="status-item">
              <label>MTOE Units</label>
              <span>{{unitBoxCount}}</span>
            </div>
            <div class="status-item">
              <label>Available Funds</label>
              <span>{{numberFormat system.cbills}} C-Bills</span>
            </div>
            <div class="status-item">
              <label>Monthly Expenses</label>
              <input type="number" min="0" name="system.monthlyExpenses" value="{{system.monthlyExpenses}}" {{#unless editable}}disabled{{/unless}} />
            </div>
          </div>

          {{!-- Personnel pool editor --}}
          <div class="pool-editor">
            <h3><i class="fas fa-users"></i> Personnel Pools</h3>
            <div class="pool-editor-group">
              <h4 class="category-title">Ship Crew</h4>
              <div class="pool-grid">
                {{#each crewPools}}
                <div class="pool-edit-cell {{#if this.over}}over{{/if}}">
                  <label>{{this.label}}</label>
                  <input type="number" min="0" name="system.personnel.{{this.key}}" value="{{this.total}}" {{#unless ../editable}}disabled{{/unless}} />
                  <span class="pool-sub">{{this.assigned}} assigned · {{this.available}} free</span>
                </div>
                {{/each}}
              </div>
            </div>
            <div class="pool-editor-group">
              <h4 class="category-title">Combat Troops</h4>
              <div class="pool-grid">
                {{#each troopPools}}
                <div class="pool-edit-cell {{#if this.over}}over{{/if}}">
                  <label>{{this.label}}</label>
                  <input type="number" min="0" name="system.personnel.{{this.key}}" value="{{this.total}}" {{#unless ../editable}}disabled{{/unless}} />
                  <span class="pool-sub">{{this.assigned}} assigned · {{this.available}} free</span>
                </div>
                {{/each}}
              </div>
            </div>
          </div>

          <div class="company-notes">
            <h3>Notes</h3>
            {{editor enrichedBiography target="system.biography" button=true owner=owner editable=editable}}
          </div>
        </div>
      </div>
    </div>

    {{!-- ==================== MTOE TAB ==================== --}}
    <div class="tab" data-tab="mtoe" data-group="primary">
      <div class="tab-content">
        <h3>Modified Table of Organization &amp; Equipment</h3>

        {{!-- Company-wide troop availability strip --}}
        <div class="pool-strip">
          {{#each troopPools}}
          <div class="pool-chip {{#if this.over}}over{{/if}}">
            <span class="pool-label">{{this.label}}</span>
            <span class="pool-count"><strong>{{this.available}}</strong> free / {{this.total}}</span>
          </div>
          {{/each}}
          <span class="pool-hint">Set totals on the Status tab</span>
        </div>

        {{#if editable}}
        <div class="mtoe-controls">
          <button type="button" class="add-mtoe-box"><i class="fas fa-plus"></i> Add Unit Box</button>
        </div>
        {{/if}}

        {{#each mtoe}}
        <div class="mtoe-box" data-box-id="{{this.id}}">
          <div class="mtoe-box-head">
            <input type="text" class="mtoe-box-name" data-box-id="{{this.id}}" value="{{this.name}}" placeholder="Unit name" {{#unless ../editable}}disabled{{/unless}} />
            <div class="mtoe-status-field">
              <label>Status</label>
              <input type="text" class="mtoe-box-status" data-box-id="{{this.id}}" value="{{this.status}}" placeholder="e.g. Combat ready" {{#unless ../editable}}disabled{{/unless}} />
            </div>
            <span class="mtoe-troop-total"><i class="fas fa-user"></i> {{this.troopTotal}}</span>
            {{#if ../editable}}
            <a class="remove-mtoe-box" data-box-id="{{this.id}}" title="Delete Unit Box"><i class="fas fa-trash"></i></a>
            {{/if}}
          </div>

          <div class="mtoe-box-body">
            {{!-- Linked equipment --}}
            <div class="mtoe-units">
              <div class="mtoe-subhead"><i class="fas fa-cogs"></i> Equipment</div>
              {{#each this.units}}
              <div class="mtoe-unit-chip {{#unless this.exists}}missing{{/unless}}">
                <img src="{{this.img}}" width="20" height="20" />
                <span class="unit-name">{{this.name}}</span>
                <span class="unit-type">{{this.typeLabel}}</span>
                {{#if ../../editable}}
                <a class="mtoe-unit-remove" data-box-id="{{../id}}" data-actor-id="{{this.id}}" title="Remove"><i class="fas fa-times"></i></a>
                {{/if}}
              </div>
              {{/each}}
              <div class="drop-zone small">Drag Mech / Vehicle / Fighter / Battle Armor actors here</div>
            </div>

            {{!-- Assigned troops --}}
            <div class="mtoe-troops">
              <div class="mtoe-subhead"><i class="fas fa-users"></i> Assigned Troops</div>
              <div class="troop-grid">
                {{#each this.troops}}
                <div class="troop-cell">
                  <label>{{this.label}}</label>
                  <input type="number" class="mtoe-troop" min="0" data-box-id="{{../id}}" data-type="{{this.key}}" value="{{this.value}}" {{#unless ../../editable}}disabled{{/unless}} />
                </div>
                {{/each}}
              </div>
            </div>
          </div>
        </div>
        {{/each}}

        {{#unless mtoe.length}}
        <p class="empty-notice">No unit boxes. Click "Add Unit Box", then drag unit actors onto it and assign troops.</p>
        {{/unless}}
      </div>
    </div>

    {{!-- ==================== ASSETS TAB ==================== --}}
    <div class="tab" data-tab="assets" data-group="primary">
      <div class="tab-content">
        <h3>Company Assets</h3>

        {{#if companyAssets.weapon.length}}
        <div class="asset-category">
          <h4 class="category-title">Weapons</h4>
          <div class="items-header flexrow">
            <div class="item-name flex3">Name</div>
            <div class="item-field flex1">Type</div>
            <div class="item-field flex1">AP</div>
            <div class="item-field flex1">BD</div>
            <div class="item-field flex1">Cost</div>
            <div class="item-controls flex1">Controls</div>
          </div>
          <ol class="item-list">
            {{#each companyAssets.weapon}}
            <li class="item flexrow" data-item-id="{{this._id}}">
              <div class="item-name flex3">{{this.name}}</div>
              <div class="item-field flex1">{{this.system.weaponType}}</div>
              <div class="item-field flex1">{{this.system.ap}}{{this.system.apFactor}}</div>
              <div class="item-field flex1">{{this.system.bd}}{{this.system.bdFactor}}</div>
              <div class="item-field flex1">{{numberFormat this.system.cost}}</div>
              <div class="item-controls flex1">
                <a class="item-edit" title="Edit"><i class="fas fa-edit"></i></a>
                <a class="item-delete" title="Delete"><i class="fas fa-trash"></i></a>
              </div>
            </li>
            {{/each}}
          </ol>
        </div>
        {{/if}}

        {{#if companyAssets.armor.length}}
        <div class="asset-category">
          <h4 class="category-title">Armor</h4>
          <div class="items-header flexrow">
            <div class="item-name flex3">Name</div>
            <div class="item-field flex1">Type</div>
            <div class="item-field flex2">BAR (M/B/E/X)</div>
            <div class="item-field flex1">Cost</div>
            <div class="item-controls flex1">Controls</div>
          </div>
          <ol class="item-list">
            {{#each companyAssets.armor}}
            <li class="item flexrow" data-item-id="{{this._id}}">
              <div class="item-name flex3">{{this.name}}</div>
              <div class="item-field flex1">{{this.system.armorType}}</div>
              <div class="item-field flex2">{{this.system.bar.m}}/{{this.system.bar.b}}/{{this.system.bar.e}}/{{this.system.bar.x}}</div>
              <div class="item-field flex1">{{numberFormat this.system.cost}}</div>
              <div class="item-controls flex1">
                <a class="item-edit" title="Edit"><i class="fas fa-edit"></i></a>
                <a class="item-delete" title="Delete"><i class="fas fa-trash"></i></a>
              </div>
            </li>
            {{/each}}
          </ol>
        </div>
        {{/if}}

        {{#if companyAssets.ammo.length}}
        <div class="asset-category">
          <h4 class="category-title">Ammunition</h4>
          <div class="items-header flexrow">
            <div class="item-name flex3">Name</div>
            <div class="item-field flex1">Category</div>
            <div class="item-field flex1">Qty</div>
            <div class="item-field flex1">Cost</div>
            <div class="item-controls flex1">Controls</div>
          </div>
          <ol class="item-list">
            {{#each companyAssets.ammo}}
            <li class="item flexrow" data-item-id="{{this._id}}">
              <div class="item-name flex3">{{this.name}}</div>
              <div class="item-field flex1">{{this.system.ammoCategory}}</div>
              <div class="item-field flex1">{{this.system.quantity.value}}/{{this.system.quantity.max}}</div>
              <div class="item-field flex1">{{numberFormat this.system.cost}}</div>
              <div class="item-controls flex1">
                <a class="item-edit" title="Edit"><i class="fas fa-edit"></i></a>
                <a class="item-delete" title="Delete"><i class="fas fa-trash"></i></a>
              </div>
            </li>
            {{/each}}
          </ol>
        </div>
        {{/if}}

        {{#if companyAssets.electronics.length}}
        <div class="asset-category">
          <h4 class="category-title">Electronics</h4>
          <div class="items-header flexrow">
            <div class="item-name flex3">Name</div>
            <div class="item-field flex1">Range</div>
            <div class="item-field flex1">Power</div>
            <div class="item-field flex1">Cost</div>
            <div class="item-controls flex1">Controls</div>
          </div>
          <ol class="item-list">
            {{#each companyAssets.electronics}}
            <li class="item flexrow" data-item-id="{{this._id}}">
              <div class="item-name flex3">{{this.name}}</div>
              <div class="item-field flex1">{{this.system.range}}</div>
              <div class="item-field flex1">{{this.system.powerUse}}</div>
              <div class="item-field flex1">{{numberFormat this.system.cost}}</div>
              <div class="item-controls flex1">
                <a class="item-edit" title="Edit"><i class="fas fa-edit"></i></a>
                <a class="item-delete" title="Delete"><i class="fas fa-trash"></i></a>
              </div>
            </li>
            {{/each}}
          </ol>
        </div>
        {{/if}}

        {{#if companyAssets.healthcare.length}}
        <div class="asset-category">
          <h4 class="category-title">Healthcare</h4>
          <div class="items-header flexrow">
            <div class="item-name flex3">Name</div>
            <div class="item-field flex1">Charges</div>
            <div class="item-field flex1">Cost</div>
            <div class="item-controls flex1">Controls</div>
          </div>
          <ol class="item-list">
            {{#each companyAssets.healthcare}}
            <li class="item flexrow" data-item-id="{{this._id}}">
              <div class="item-name flex3">{{this.name}}</div>
              <div class="item-field flex1">{{this.system.charges.value}}/{{this.system.charges.max}}</div>
              <div class="item-field flex1">{{numberFormat this.system.cost}}</div>
              <div class="item-controls flex1">
                <a class="item-edit" title="Edit"><i class="fas fa-edit"></i></a>
                <a class="item-delete" title="Delete"><i class="fas fa-trash"></i></a>
              </div>
            </li>
            {{/each}}
          </ol>
        </div>
        {{/if}}

        {{#if companyAssets.fuel.length}}
        <div class="asset-category">
          <h4 class="category-title">Fuel</h4>
          <div class="items-header flexrow">
            <div class="item-name flex3">Name</div>
            <div class="item-field flex1">Type</div>
            <div class="item-field flex1">Mass</div>
            <div class="item-controls flex1">Controls</div>
          </div>
          <ol class="item-list">
            {{#each companyAssets.fuel}}
            <li class="item flexrow" data-item-id="{{this._id}}">
              <div class="item-name flex3">{{this.name}}</div>
              <div class="item-field flex1">{{this.system.fuelType}}</div>
              <div class="item-field flex1">{{this.system.mass}}</div>
              <div class="item-controls flex1">
                <a class="item-edit" title="Edit"><i class="fas fa-edit"></i></a>
                <a class="item-delete" title="Delete"><i class="fas fa-trash"></i></a>
              </div>
            </li>
            {{/each}}
          </ol>
        </div>
        {{/if}}

        {{#if companyAssets.prosthetics.length}}
        <div class="asset-category">
          <h4 class="category-title">Prosthetics</h4>
          <div class="items-header flexrow">
            <div class="item-name flex3">Name</div>
            <div class="item-field flex1">Rating</div>
            <div class="item-field flex1">Cost</div>
            <div class="item-controls flex1">Controls</div>
          </div>
          <ol class="item-list">
            {{#each companyAssets.prosthetics}}
            <li class="item flexrow" data-item-id="{{this._id}}">
              <div class="item-name flex3">{{this.name}}</div>
              <div class="item-field flex1">{{this.system.equipmentRating}}</div>
              <div class="item-field flex1">{{numberFormat this.system.cost}}</div>
              <div class="item-controls flex1">
                <a class="item-edit" title="Edit"><i class="fas fa-edit"></i></a>
                <a class="item-delete" title="Delete"><i class="fas fa-trash"></i></a>
              </div>
            </li>
            {{/each}}
          </ol>
        </div>
        {{/if}}

        {{#if companyAssets.drugpoison.length}}
        <div class="asset-category">
          <h4 class="category-title">Drugs &amp; Poisons</h4>
          <div class="items-header flexrow">
            <div class="item-name flex3">Name</div>
            <div class="item-field flex1">Strength</div>
            <div class="item-field flex1">Cost</div>
            <div class="item-controls flex1">Controls</div>
          </div>
          <ol class="item-list">
            {{#each companyAssets.drugpoison}}
            <li class="item flexrow" data-item-id="{{this._id}}">
              <div class="item-name flex3">{{this.name}}</div>
              <div class="item-field flex1">{{this.system.drugStrength}}</div>
              <div class="item-field flex1">{{numberFormat this.system.basePrice}}</div>
              <div class="item-controls flex1">
                <a class="item-edit" title="Edit"><i class="fas fa-edit"></i></a>
                <a class="item-delete" title="Delete"><i class="fas fa-trash"></i></a>
              </div>
            </li>
            {{/each}}
          </ol>
        </div>
        {{/if}}

        {{#unless companyAssets.hasItems}}
        <p class="empty-notice">Drag equipment items here to add them as company assets.</p>
        {{/unless}}
      </div>
    </div>

    {{!-- ==================== FINANCES TAB ==================== --}}
    <div class="tab" data-tab="finances" data-group="primary">
      <div class="tab-content">
        <div class="finance-controls">
          <button type="button" class="pay-monthly-expenses">
            <i class="fas fa-money-bill-wave"></i> Pay Monthly Expenses ({{numberFormat system.monthlyExpenses}} C-Bills)
          </button>
        </div>

        <h3>Transaction History</h3>
        <div class="items-header finance-header flexrow">
          <div class="item-field flex2">Date</div>
          <div class="item-field flex2">Submitted By</div>
          <div class="item-field flex1">Type</div>
          <div class="item-field flex1">Amount</div>
          <div class="item-field flex2">Reason</div>
          <div class="item-field flex1">Balance</div>
          {{#if isGM}}
          <div class="item-controls ledger-controls">Del</div>
          {{/if}}
        </div>
        <ol class="item-list finance-list">
          {{#each financialLedger}}
          <li class="item flexrow ledger-entry {{this.type}}" data-ledger-id="{{this.id}}">
            <div class="item-field flex2">{{this.formattedDate}}</div>
            <div class="item-field flex2">{{this.submittedBy}}</div>
            <div class="item-field flex1 transaction-type">
              {{#if (eq this.type "add")}}
              <span class="funds-add">+ Deposit</span>
              {{else}}
              <span class="funds-remove">- Withdrawal</span>
              {{/if}}
            </div>
            <div class="item-field flex1">{{this.amount}}</div>
            <div class="item-field flex2">{{this.reason}}</div>
            <div class="item-field flex1">{{this.balance}}</div>
            {{#if ../isGM}}
            <div class="item-controls ledger-controls">
              <a class="ledger-delete" data-ledger-id="{{this.id}}" title="Delete Entry"><i class="fas fa-trash"></i></a>
            </div>
            {{/if}}
          </li>
          {{/each}}
        </ol>
        {{#unless financialLedger.length}}
        <p class="empty-notice">No transactions recorded yet.</p>
        {{/unless}}
      </div>
    </div>

  </section>
</div>
