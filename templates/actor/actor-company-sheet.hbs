<div class="company-sheet-content actor-sheet-content">

  {{!-- Company Header --}}
  <header class="sheet-header company-header">
    <img class="profile-img" src="{{actor.img}}" data-action="editImage" data-edit="img" title="{{actor.name}}" height="70" width="70" />
    <div class="header-fields">
      <h1 class="company-name">
        <input name="name" type="text" value="{{actor.name}}" placeholder="Company Name" />
      </h1>
      <div class="company-summary">
        <div class="summary-field cbills-field">
          <label>C-Bills</label>
          <div class="cbills-display">
            <span class="cbills-value computed-value">{{numberFormat system.cbills}}</span>
            {{#if editable}}
            <div class="cbills-controls">
              <button type="button" class="cbills-add" title="Add Funds"><i class="fas fa-plus"></i></button>
              <button type="button" class="cbills-remove" title="Remove Funds"><i class="fas fa-minus"></i></button>
            </div>
            {{/if}}
          </div>
        </div>
        <div class="summary-field">
          <label>Personnel</label>
          <span class="computed-value">{{totalPersonnel}}</span>
        </div>
        <div class="summary-field">
          <label>Locations</label>
          <span class="computed-value">{{locationCount}}</span>
        </div>
        <div class="summary-field">
          <label>Reputation</label>
          <input type="text" name="system.reputation" value="{{system.reputation}}" class="reputation-input" />
        </div>
      </div>
    </div>
  </header>

  {{!-- Tab Navigation --}}
  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="locations">Locations</a>
    <a class="item" data-tab="logistics">Logistics</a>
    <a class="item" data-tab="status">Status</a>
    <a class="item" data-tab="mtoe">MTOE</a>
    <a class="item" data-tab="assets">Assets</a>
    <a class="item" data-tab="finances">Finances</a>
  </nav>

  <section class="sheet-body">

    {{!-- ==================== LOCATIONS TAB ==================== --}}
    <div class="tab" data-tab="locations" data-group="primary">
      <div class="tab-content">

        <div class="pool-strip">
          {{#each crewPools}}
          <div class="pool-chip {{#if this.over}}over{{/if}}">
            <span class="pool-label">{{this.label}}</span>
            <span class="pool-count"><span class="pool-free">{{this.available}}</span> free / <span class="pool-assigned">{{this.assigned}}</span> assigned</span>
          </div>
          {{/each}}
          <span class="pool-hint">Totals on the Status tab</span>
        </div>

        <p class="drop-hint"><i class="fas fa-anchor"></i> Drag a Naval Ship or Installation actor here to add it as a location.</p>

        {{#each locations}}
        <div class="location-card" data-loc-id="{{this.id}}">
          <div class="location-head">
            <img src="{{this.img}}" width="40" height="40" />
            <div class="location-title">
              <span class="location-name">{{this.name}}</span>
              <span class="location-type">{{this.typeLabel}}{{#unless this.exists}} — actor deleted{{/unless}}</span>
            </div>
            <div class="location-status-field">
              <label>Status</label>
              <input type="text" class="location-status" data-loc-id="{{this.id}}" value="{{this.status}}" placeholder="e.g. On station" {{#unless ../editable}}disabled{{/unless}} />
            </div>
            <span class="location-crew-total"><i class="fas fa-users"></i> {{this.crewAssignedTotal}} crew</span>
            {{#if ../editable}}
            <a class="location-remove" data-loc-id="{{this.id}}" title="Remove Location"><i class="fas fa-times"></i></a>
            {{/if}}
          </div>

          <div class="location-body">
            <div class="dept-block-header">
              <span><i class="fas fa-sitemap"></i> Departments</span>
              <span class="dept-block-note">Defined on the vessel sheet · assign crew here</span>
            </div>

            {{#each this.departments}}
            <div class="dept-row {{#if this.understaffed}}understaffed{{/if}}">
              <div class="dept-row-top">
                <span class="dept-type-label">{{this.typeLabel}}</span>

                <span class="vet-badge vet-{{this.veterancy}}">{{this.veterancy}} ({{#if (gte this.vetMod 0)}}+{{/if}}{{this.vetMod}})</span>
                <div class="xp-track" title="{{this.xpInto}}/100 XP to next tier">
                  <div class="xp-fill" style="width:{{this.xpPct}}%"></div>
                </div>
                <input type="number" class="dept-xp xp-input" min="0" data-loc-id="{{../id}}" data-dept-id="{{this.id}}" value="{{this.xp}}" title="Total XP" {{#unless ../../editable}}disabled{{/unless}} />

                <span class="staff-badge {{#unless this.canRoll}}disabled{{/unless}}">{{this.staffPct}}%</span>
                <button type="button" class="dept-roll" data-loc-id="{{../id}}" data-dept-id="{{this.id}}"
                        title="{{#if this.canRoll}}Roll a department task{{else}}Below 50% staffing — cannot roll{{/if}}"
                        {{#unless this.canRoll}}disabled{{/unless}}><i class="fas fa-dice"></i></button>
              </div>

              <div class="dept-crew-grid">
                {{#each this.crew}}
                <div class="dept-crew-cell">
                  <span class="dept-crew-label">{{this.label}}</span>
                  <span class="dept-crew-inputs">
                    <input type="number" class="dept-assign" min="0"
                           data-loc-id="{{../../id}}" data-dept-id="{{../id}}" data-slot="{{this.slot}}"
                           value="{{this.assigned}}" title="Assigned" {{#unless ../../../editable}}disabled{{/unless}} />
                    <span class="dept-crew-sep">/</span>
                    <span class="dept-req-val" title="Required (set on vessel)">{{this.required}}</span>
                  </span>
                </div>
                {{/each}}
                <span class="dept-fill {{#if this.understaffed}}short{{/if}}">Staffed {{this.assignedTotal}}/{{this.reqTotal}}</span>
              </div>
            </div>
            {{/each}}
            {{#unless this.departments.length}}
            {{#if this.deptSupported}}
            <p class="empty-notice small">No departments defined on this vessel yet — add them on its actor sheet.</p>
            {{else}}
            <p class="empty-notice small">This location type doesn't define departments yet.</p>
            {{/if}}
            {{/unless}}
          </div>
        </div>
        {{/each}}

        {{#unless locations.length}}
        <p class="empty-notice">No locations. Drag a Naval Ship or Installation actor here.</p>
        {{/unless}}
      </div>
    </div>

    {{!-- ==================== LOGISTICS TAB ==================== --}}
    <div class="tab" data-tab="logistics" data-group="primary">
      <div class="tab-content">

        <div class="logi-section">
          <h3><i class="fas fa-ship"></i> Ship Supplies</h3>
          {{#each shipLocations}}
          <div class="logi-location" data-loc-id="{{this.id}}">
            <div class="logi-location-head">
              <img src="{{this.img}}" width="24" height="24" />
              <span class="location-name">{{this.name}}</span>
              <span class="location-type">{{this.typeLabel}}</span>
            </div>
            <div class="supply-grid">
              {{#each this.supplies}}
              <div class="supply-cell">
                <label>{{this.label}}</label>
                <input type="number" class="ship-supply" min="0" data-loc-id="{{../id}}" data-key="{{this.key}}" value="{{this.value}}" {{#unless ../../editable}}disabled{{/unless}} />
              </div>
              {{/each}}
            </div>
            <div class="ammo-block">
              <div class="ammo-block-head">
                <span><i class="fas fa-box"></i> Ammo Types</span>
                {{#if ../editable}}
                <button type="button" class="add-ship-ammo" data-loc-id="{{this.id}}"><i class="fas fa-plus"></i> Add Ammo</button>
                {{/if}}
              </div>
              {{#each this.ammo}}
              <div class="ammo-row">
                <input type="text" class="ship-ammo-field" data-loc-id="{{../id}}" data-ammo-id="{{this.id}}" data-field="name" value="{{this.name}}" placeholder="Ammo type" {{#unless ../../editable}}disabled{{/unless}} />
                <input type="number" class="ship-ammo-field" min="0" data-loc-id="{{../id}}" data-ammo-id="{{this.id}}" data-field="value" value="{{this.value}}" placeholder="Qty" {{#unless ../../editable}}disabled{{/unless}} />
                {{#if ../../editable}}
                <a class="remove-ship-ammo" data-loc-id="{{../id}}" data-ammo-id="{{this.id}}" title="Remove"><i class="fas fa-times"></i></a>
                {{/if}}
              </div>
              {{/each}}
              <p class="logi-note">Auto-population of needed ammo types from ship sheets will be wired once those sheets carry weapon data.</p>
            </div>
          </div>
          {{/each}}
          {{#unless shipLocations.length}}
          <p class="empty-notice">Add ship / installation locations first (Locations tab).</p>
          {{/unless}}
        </div>

        <div class="logi-section">
          <h3><i class="fas fa-truck-field"></i> Ground Forces Supplies</h3>
          <p class="logi-note">Stored in ship cargo, used by deployed troops.</p>
          {{#each groundSupplyGroups}}
          <div class="ground-group">
            <h4 class="category-title">{{this.label}}</h4>
            <div class="supply-grid">
              {{#each this.fields}}
              <div class="supply-cell">
                <label>{{this.label}}</label>
                <input type="number" min="0" name="system.groundSupplies.{{this.key}}" value="{{lookup ../../system.groundSupplies this.key}}" {{#unless ../../editable}}disabled{{/unless}} />
              </div>
              {{/each}}
            </div>
          </div>
          {{/each}}

          <div class="ammo-block">
            <div class="ammo-block-head">
              <span><i class="fas fa-box"></i> Ammo Types</span>
              {{#if editable}}
              <button type="button" class="add-ground-ammo"><i class="fas fa-plus"></i> Add Ammo</button>
              {{/if}}
            </div>
            {{#each system.groundSupplies.ammo}}
            <div class="ammo-row wide">
              <input type="text" class="ground-ammo-field" data-ammo-id="{{this.id}}" data-field="name" value="{{this.name}}" placeholder="Ammo type" {{#unless ../editable}}disabled{{/unless}} />
              <input type="text" class="ground-ammo-field" data-ammo-id="{{this.id}}" data-field="usedBy" value="{{this.usedBy}}" placeholder="Used by (unit)" {{#unless ../editable}}disabled{{/unless}} />
              <input type="number" class="ground-ammo-field" min="0" data-ammo-id="{{this.id}}" data-field="value" value="{{this.value}}" placeholder="Qty" {{#unless ../editable}}disabled{{/unless}} />
              {{#if ../editable}}
              <a class="remove-ground-ammo" data-ammo-id="{{this.id}}" title="Remove"><i class="fas fa-times"></i></a>
              {{/if}}
            </div>
            {{/each}}
            <p class="logi-note">Auto-summing ammo needs from assigned units will be wired once unit sheets carry weapon data.</p>
          </div>
        </div>
      </div>
    </div>

    {{!-- ==================== STATUS TAB ==================== --}}
    <div class="tab" data-tab="status" data-group="primary">
      <div class="tab-content">
        <div class="status-section">
          <h3>Company Status</h3>
          <div class="status-overview">
            <div class="status-item"><label>Total Personnel</label><span>{{totalPersonnel}}</span></div>
            <div class="status-item"><label>Locations</label><span>{{locationCount}}</span></div>
            <div class="status-item"><label>MTOE Units</label><span>{{unitBoxCount}}</span></div>
            <div class="status-item"><label>Available Funds</label><span>{{numberFormat system.cbills}} C-Bills</span></div>
            <div class="status-item"><label>Monthly Salaries</label><span>{{numberFormat monthlyExpenses}} C-Bills</span></div>
          </div>

          {{!-- Personnel pool editor --}}
          <div class="pool-editor">
            <h3><i class="fas fa-users"></i> Personnel Pools</h3>
            <div class="pool-editor-group">
              <h4 class="category-title">Ship Crew</h4>
              <div class="pool-grid">
                {{#each crewPools}}
                <div class="pool-edit-cell {{#if this.over}}over{{/if}}">
                  <label>{{this.label}}</label>
                  <input type="number" min="0" name="system.personnel.{{this.key}}" value="{{this.total}}" {{#unless ../editable}}disabled{{/unless}} />
                  <span class="pool-sub"><span class="pool-assigned">{{this.assigned}}</span> assigned · <span class="pool-free">{{this.available}}</span> free · {{numberFormat this.salary}} C-Bills ea.</span>
                </div>
                {{/each}}
              </div>
            </div>
            <div class="pool-editor-group">
              <h4 class="category-title">Combat Troops</h4>
              <div class="pool-grid">
                {{#each troopPools}}
                <div class="pool-edit-cell {{#if this.over}}over{{/if}}">
                  <label>{{this.label}}</label>
                  <input type="number" min="0" name="system.personnel.{{this.key}}" value="{{this.total}}" {{#unless ../editable}}disabled{{/unless}} />
                  <span class="pool-sub"><span class="pool-assigned">{{this.assigned}}</span> assigned · <span class="pool-free">{{this.available}}</span> free · {{numberFormat this.salary}} C-Bills ea.</span>
                </div>
                {{/each}}
              </div>
            </div>
          </div>

          {{!-- Medical status framework --}}
          <div class="medical-section">
            <h3><i class="fas fa-kit-medical"></i> Medical</h3>
            <table class="medical-table">
              <thead>
                <tr>
                  <th class="med-type-col">Personnel Type</th>
                  {{#each medicalStatuses}}<th>{{this.label}}</th>{{/each}}
                </tr>
              </thead>
              <tbody>
                {{#each medicalRows}}
                <tr>
                  <td class="med-type-col">{{this.label}}</td>
                  {{#each this.cells}}
                  <td><input type="number" min="0" name="system.medical.{{../key}}.{{this.key}}" value="{{this.value}}" {{#unless ../../editable}}disabled{{/unless}} /></td>
                  {{/each}}
                </tr>
                {{/each}}
              </tbody>
              <tfoot>
                <tr class="med-total-row">
                  <td class="med-type-col">Total</td>
                  {{#each medicalTotals}}<td>{{this.value}}</td>{{/each}}
                </tr>
              </tfoot>
            </table>
          </div>

          <div class="company-notes">
            <h3>Notes</h3>
            <div class="editor-container">
              {{#if editable}}
              <prose-mirror name="system.biography" data-document-uuid="{{actor.uuid}}" value="{{system.biography}}" collaborate="false" toggled="true">{{{enrichedBiography}}}</prose-mirror>
              {{else}}{{{enrichedBiography}}}{{/if}}
            </div>
          </div>
        </div>
      </div>
    </div>

    {{!-- ==================== MTOE TAB ==================== --}}
    <div class="tab" data-tab="mtoe" data-group="primary">
      <div class="tab-content">
        <h3>Modified Table of Organization &amp; Equipment</h3>

        <div class="pool-strip">
          {{#each troopPools}}
          <div class="pool-chip {{#if this.over}}over{{/if}}">
            <span class="pool-label">{{this.label}}</span>
            <span class="pool-count"><span class="pool-free">{{this.available}}</span> free / <span class="pool-assigned">{{this.assigned}}</span> assigned</span>
          </div>
          {{/each}}
          <span class="pool-hint">Totals on the Status tab</span>
        </div>

        {{#if editable}}
        <div class="mtoe-controls">
          <button type="button" class="add-mtoe-box"><i class="fas fa-plus"></i> Add Unit Box</button>
        </div>
        {{/if}}

        <div class="mtoe-boxes">
        {{#each mtoe}}
        <div class="mtoe-box" data-box-id="{{this.id}}">
          <div class="mtoe-box-head">
            <input type="text" class="mtoe-box-name" data-box-id="{{this.id}}" value="{{this.name}}" placeholder="Unit name" {{#unless ../editable}}disabled{{/unless}} />
            {{#if ../editable}}
            <a class="remove-mtoe-box" data-box-id="{{this.id}}" title="Delete Unit Box"><i class="fas fa-trash"></i></a>
            {{/if}}
          </div>

          <div class="mtoe-box-controls">
            <label class="ctl">Personnel
              <select class="mtoe-personnel-type" data-box-id="{{this.id}}" {{#unless ../editable}}disabled{{/unless}}>
                {{#each ../troopTypes}}
                <option value="{{this.key}}" {{#if (eq this.key ../personnelType)}}selected{{/if}}>{{this.label}}</option>
                {{/each}}
              </select>
            </label>
            <label class="ctl">Status
              <select class="mtoe-box-status" data-box-id="{{this.id}}" {{#unless ../editable}}disabled{{/unless}}>
                {{#each ../unitStatuses}}
                <option value="{{this}}" {{#if (eq this ../status)}}selected{{/if}}>{{this}}</option>
                {{/each}}
              </select>
            </label>
          </div>

          <div class="mtoe-box-vet">
            <span class="vet-badge vet-{{this.veterancy}}">{{this.veterancy}} ({{#if (gte this.vetMod 0)}}+{{/if}}{{this.vetMod}})</span>
            <div class="xp-track" title="{{this.xpInto}}/100 XP to next tier"><div class="xp-fill" style="width:{{this.xpPct}}%"></div></div>
            <input type="number" class="mtoe-xp xp-input" min="0" data-box-id="{{this.id}}" value="{{this.xp}}" title="Total XP" {{#unless ../editable}}disabled{{/unless}} />
            <button type="button" class="mtoe-roll" data-box-id="{{this.id}}" title="Roll a unit task"><i class="fas fa-dice"></i></button>
          </div>

          {{#if this.mismatch}}
          <div class="mtoe-warning"><i class="fas fa-triangle-exclamation"></i> {{this.mismatch}}</div>
          {{/if}}

          {{!-- Paired personnel / vehicle rows --}}
          <div class="mtoe-roster">
            <div class="roster-head">
              <span>{{this.personnelTypeLabel}} ({{this.troopTotal}})</span>
              <span>{{#if this.allowedVehicleLabel}}{{this.allowedVehicleLabel}} ({{this.vehicleTotal}}){{else}}No vehicles{{/if}}</span>
            </div>
            {{#each this.rows}}
            <div class="roster-row">
              <div class="roster-person">
                {{#if this.person}}
                <span class="rp-name">{{this.person.label}}</span>
                <select class="person-status status-{{this.person.status}}" data-box-id="{{../id}}" data-person-id="{{this.person.id}}" {{#unless ../../editable}}disabled{{/unless}}>
                  {{#each ../../personStatuses}}<option value="{{this}}" {{#if (eq this ../person.status)}}selected{{/if}}>{{this}}</option>{{/each}}
                </select>
                {{#if ../../editable}}
                <a class="remove-personnel" data-box-id="{{../id}}" data-person-id="{{this.person.id}}" title="Remove"><i class="fas fa-times"></i></a>
                {{/if}}
                {{else}}
                <span class="rp-empty">—</span>
                {{/if}}
              </div>
              <div class="roster-vehicle">
                {{#if this.vehicle}}
                <a class="mtoe-unit-open {{#unless this.vehicle.exists}}missing{{/unless}}" data-actor-id="{{this.vehicle.actorId}}" title="Open sheet">
                  <img src="{{this.vehicle.img}}" width="18" height="18" />{{this.vehicle.name}}
                </a>
                <select class="vehicle-status vstatus-{{this.vehicle.status}}" data-box-id="{{../id}}" data-actor-id="{{this.vehicle.actorId}}" {{#unless ../../editable}}disabled{{/unless}}>
                  {{#each ../../vehicleStatuses}}<option value="{{this}}" {{#if (eq this ../vehicle.status)}}selected{{/if}}>{{this}}</option>{{/each}}
                </select>
                {{#if ../../editable}}
                <a class="mtoe-unit-remove" data-box-id="{{../id}}" data-actor-id="{{this.vehicle.actorId}}" title="Remove"><i class="fas fa-times"></i></a>
                {{/if}}
                {{else}}
                <span class="rp-empty">—</span>
                {{/if}}
              </div>
            </div>
            {{/each}}
            {{#unless this.rows.length}}
            <p class="empty-notice small">No personnel or vehicles yet.</p>
            {{/unless}}
          </div>

          {{#if ../editable}}
          <div class="mtoe-box-actions">
            <button type="button" class="add-personnel" data-box-id="{{this.id}}"><i class="fas fa-user-plus"></i> Add {{this.personnelTypeLabel}}</button>
            {{#if this.allowedVehicleLabel}}
            <span class="drop-zone small">Drag {{this.allowedVehicleLabel}} actors here</span>
            {{/if}}
          </div>
          {{/if}}
        </div>
        {{/each}}
        </div>

        {{#unless mtoe.length}}
        <p class="empty-notice">No unit boxes. Click "Add Unit Box", pick a personnel type, then add personnel and drag matching vehicles onto it.</p>
        {{/unless}}
      </div>
    </div>

    {{!-- ==================== ASSETS TAB ==================== --}}
    <div class="tab" data-tab="assets" data-group="primary">
      <div class="tab-content assets-tab">
        <h3>Company Assets</h3>

        {{#if companyAssets.weapon.length}}
        <div class="asset-category">
          <h4 class="category-title">Weapons</h4>
          <div class="asset-grid asset-header">
            <div class="ac-name">Name</div><div>Type</div><div>AP</div><div>BD</div><div class="ac-qty">Qty</div><div class="ac-cost">Cost</div><div class="ac-ctrl">Controls</div>
          </div>
          {{#each companyAssets.weapon}}
          <div class="asset-grid asset-row" data-item-id="{{this._id}}">
            <div class="ac-name">{{this.name}}</div>
            <div>{{this.system.weaponType}}</div>
            <div>{{this.system.ap}}{{this.system.apFactor}}</div>
            <div>{{this.system.bd}}{{this.system.bdFactor}}</div>
            <div class="ac-qty">{{this.qty}}</div><div class="ac-cost">{{numberFormat this.system.cost}}</div>
            <div class="ac-ctrl"><a class="item-edit" title="Edit"><i class="fas fa-edit"></i></a><a class="item-delete" title="Delete"><i class="fas fa-trash"></i></a></div>
          </div>
          {{/each}}
        </div>
        {{/if}}

        {{#if companyAssets.armor.length}}
        <div class="asset-category">
          <h4 class="category-title">Armor</h4>
          <div class="asset-grid asset-header">
            <div class="ac-name">Name</div><div>Type</div><div>BAR (M/B/E/X)</div><div></div><div class="ac-qty">Qty</div><div class="ac-cost">Cost</div><div class="ac-ctrl">Controls</div>
          </div>
          {{#each companyAssets.armor}}
          <div class="asset-grid asset-row" data-item-id="{{this._id}}">
            <div class="ac-name">{{this.name}}</div>
            <div>{{this.system.armorType}}</div>
            <div>{{this.system.bar.m}}/{{this.system.bar.b}}/{{this.system.bar.e}}/{{this.system.bar.x}}</div>
            <div></div>
            <div class="ac-qty">{{this.qty}}</div><div class="ac-cost">{{numberFormat this.system.cost}}</div>
            <div class="ac-ctrl"><a class="item-edit" title="Edit"><i class="fas fa-edit"></i></a><a class="item-delete" title="Delete"><i class="fas fa-trash"></i></a></div>
          </div>
          {{/each}}
        </div>
        {{/if}}

        {{#if companyAssets.ammo.length}}
        <div class="asset-category">
          <h4 class="category-title">Ammunition</h4>
          <div class="asset-grid asset-header">
            <div class="ac-name">Name</div><div>Category</div><div>Qty</div><div></div><div class="ac-qty">Qty</div><div class="ac-cost">Cost</div><div class="ac-ctrl">Controls</div>
          </div>
          {{#each companyAssets.ammo}}
          <div class="asset-grid asset-row" data-item-id="{{this._id}}">
            <div class="ac-name">{{this.name}}</div>
            <div>{{this.system.ammoCategory}}</div>
            <div>{{this.system.quantity.value}}/{{this.system.quantity.max}}</div>
            <div></div>
            <div class="ac-qty">{{this.qty}}</div><div class="ac-cost">{{numberFormat this.system.cost}}</div>
            <div class="ac-ctrl"><a class="item-edit" title="Edit"><i class="fas fa-edit"></i></a><a class="item-delete" title="Delete"><i class="fas fa-trash"></i></a></div>
          </div>
          {{/each}}
        </div>
        {{/if}}

        {{#if companyAssets.electronics.length}}
        <div class="asset-category">
          <h4 class="category-title">Electronics</h4>
          <div class="asset-grid asset-header">
            <div class="ac-name">Name</div><div>Range</div><div>Power</div><div></div><div class="ac-qty">Qty</div><div class="ac-cost">Cost</div><div class="ac-ctrl">Controls</div>
          </div>
          {{#each companyAssets.electronics}}
          <div class="asset-grid asset-row" data-item-id="{{this._id}}">
            <div class="ac-name">{{this.name}}</div>
            <div>{{this.system.range}}</div>
            <div>{{this.system.powerUse}}</div>
            <div></div>
            <div class="ac-qty">{{this.qty}}</div><div class="ac-cost">{{numberFormat this.system.cost}}</div>
            <div class="ac-ctrl"><a class="item-edit" title="Edit"><i class="fas fa-edit"></i></a><a class="item-delete" title="Delete"><i class="fas fa-trash"></i></a></div>
          </div>
          {{/each}}
        </div>
        {{/if}}

        {{#if companyAssets.healthcare.length}}
        <div class="asset-category">
          <h4 class="category-title">Healthcare</h4>
          <div class="asset-grid asset-header">
            <div class="ac-name">Name</div><div>Charges</div><div></div><div></div><div class="ac-qty">Qty</div><div class="ac-cost">Cost</div><div class="ac-ctrl">Controls</div>
          </div>
          {{#each companyAssets.healthcare}}
          <div class="asset-grid asset-row" data-item-id="{{this._id}}">
            <div class="ac-name">{{this.name}}</div>
            <div>{{this.system.charges.value}}/{{this.system.charges.max}}</div>
            <div></div>
            <div></div>
            <div class="ac-qty">{{this.qty}}</div><div class="ac-cost">{{numberFormat this.system.cost}}</div>
            <div class="ac-ctrl"><a class="item-edit" title="Edit"><i class="fas fa-edit"></i></a><a class="item-delete" title="Delete"><i class="fas fa-trash"></i></a></div>
          </div>
          {{/each}}
        </div>
        {{/if}}

        {{#if companyAssets.fuel.length}}
        <div class="asset-category">
          <h4 class="category-title">Fuel</h4>
          <div class="asset-grid asset-header">
            <div class="ac-name">Name</div><div>Type</div><div>Mass</div><div></div><div class="ac-qty">Qty</div><div class="ac-cost">Cost</div><div class="ac-ctrl">Controls</div>
          </div>
          {{#each companyAssets.fuel}}
          <div class="asset-grid asset-row" data-item-id="{{this._id}}">
            <div class="ac-name">{{this.name}}</div>
            <div>{{this.system.fuelType}}</div>
            <div>{{this.system.mass}}</div>
            <div></div>
            <div class="ac-qty">{{this.qty}}</div><div class="ac-cost">—</div>
            <div class="ac-ctrl"><a class="item-edit" title="Edit"><i class="fas fa-edit"></i></a><a class="item-delete" title="Delete"><i class="fas fa-trash"></i></a></div>
          </div>
          {{/each}}
        </div>
        {{/if}}

        {{#if companyAssets.prosthetics.length}}
        <div class="asset-category">
          <h4 class="category-title">Prosthetics</h4>
          <div class="asset-grid asset-header">
            <div class="ac-name">Name</div><div>Rating</div><div></div><div></div><div class="ac-qty">Qty</div><div class="ac-cost">Cost</div><div class="ac-ctrl">Controls</div>
          </div>
          {{#each companyAssets.prosthetics}}
          <div class="asset-grid asset-row" data-item-id="{{this._id}}">
            <div class="ac-name">{{this.name}}</div>
            <div>{{this.system.equipmentRating}}</div>
            <div></div>
            <div></div>
            <div class="ac-qty">{{this.qty}}</div><div class="ac-cost">{{numberFormat this.system.cost}}</div>
            <div class="ac-ctrl"><a class="item-edit" title="Edit"><i class="fas fa-edit"></i></a><a class="item-delete" title="Delete"><i class="fas fa-trash"></i></a></div>
          </div>
          {{/each}}
        </div>
        {{/if}}

        {{#if companyAssets.drugpoison.length}}
        <div class="asset-category">
          <h4 class="category-title">Drugs &amp; Poisons</h4>
          <div class="asset-grid asset-header">
            <div class="ac-name">Name</div><div>Strength</div><div></div><div></div><div class="ac-qty">Qty</div><div class="ac-cost">Cost</div><div class="ac-ctrl">Controls</div>
          </div>
          {{#each companyAssets.drugpoison}}
          <div class="asset-grid asset-row" data-item-id="{{this._id}}">
            <div class="ac-name">{{this.name}}</div>
            <div>{{this.system.drugStrength}}</div>
            <div></div>
            <div></div>
            <div class="ac-qty">{{this.qty}}</div><div class="ac-cost">{{numberFormat this.system.basePrice}}</div>
            <div class="ac-ctrl"><a class="item-edit" title="Edit"><i class="fas fa-edit"></i></a><a class="item-delete" title="Delete"><i class="fas fa-trash"></i></a></div>
          </div>
          {{/each}}
        </div>
        {{/if}}

        {{#unless companyAssets.hasItems}}
        <p class="empty-notice">Drag equipment items here to add them as company assets.</p>
        {{/unless}}
      </div>
    </div>

    {{!-- ==================== FINANCES TAB ==================== --}}
    <div class="tab" data-tab="finances" data-group="primary">
      <div class="tab-content">
        <div class="finance-controls">
          <button type="button" class="pay-monthly-expenses">
            <i class="fas fa-money-bill-wave"></i> Pay Monthly Salaries ({{numberFormat monthlyExpenses}} C-Bills)
          </button>
        </div>

        <h3>Transaction History</h3>
        <div class="items-header finance-header flexrow">
          <div class="item-field flex2">Date</div>
          <div class="item-field flex2">Submitted By</div>
          <div class="item-field flex1">Type</div>
          <div class="item-field flex1">Amount</div>
          <div class="item-field flex2">Reason</div>
          <div class="item-field flex1">Balance</div>
          {{#if isGM}}
          <div class="item-controls ledger-controls">Del</div>
          {{/if}}
        </div>
        <ol class="item-list finance-list">
          {{#each financialLedger}}
          <li class="item flexrow ledger-entry {{this.type}}" data-ledger-id="{{this.id}}">
            <div class="item-field flex2">{{this.formattedDate}}</div>
            <div class="item-field flex2">{{this.submittedBy}}</div>
            <div class="item-field flex1 transaction-type">
              {{#if (eq this.type "add")}}<span class="funds-add">+ Deposit</span>{{else}}<span class="funds-remove">- Withdrawal</span>{{/if}}
            </div>
            <div class="item-field flex1">{{this.amount}}</div>
            <div class="item-field flex2">{{this.reason}}</div>
            <div class="item-field flex1">{{this.balance}}</div>
            {{#if ../isGM}}
            <div class="item-controls ledger-controls">
              <a class="ledger-delete" data-ledger-id="{{this.id}}" title="Delete Entry"><i class="fas fa-trash"></i></a>
            </div>
            {{/if}}
          </li>
          {{/each}}
        </ol>
        {{#unless financialLedger.length}}
        <p class="empty-notice">No transactions recorded yet.</p>
        {{/unless}}
      </div>
    </div>

  </section>
</div>
