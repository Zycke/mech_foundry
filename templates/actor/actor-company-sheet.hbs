<div class="company-sheet-content actor-sheet-content">

  {{!-- Company Header --}}
  <header class="sheet-header company-header">
    <img class="profile-img" src="{{actor.img}}" data-action="editImage" data-edit="img" title="{{actor.name}}" height="70" width="70" />
    <div class="header-fields">
      <h1 class="company-name">
        <input name="name" type="text" value="{{actor.name}}" placeholder="Company Name" />
      </h1>
      <div class="company-summary">
        <div class="summary-field cbills-field">
          <label>C-Bills</label>
          <div class="cbills-display">
            <span class="cbills-value computed-value">{{numberFormat system.cbills}}</span>
            {{#if editable}}
            <div class="cbills-controls">
              <button type="button" class="cbills-add" title="Add Funds"><i class="fas fa-plus"></i></button>
              <button type="button" class="cbills-remove" title="Remove Funds"><i class="fas fa-minus"></i></button>
            </div>
            {{/if}}
          </div>
        </div>
        <div class="summary-field">
          <label>Personnel</label>
          <span class="computed-value">{{totalPersonnel}}</span>
        </div>
        <div class="summary-field">
          <label>Locations</label>
          <span class="computed-value">{{locationCount}}</span>
        </div>
        <div class="summary-field">
          <label>Reputation</label>
          <input type="text" name="system.reputation" value="{{system.reputation}}" class="reputation-input" />
        </div>
      </div>
    </div>
  </header>

  {{!-- Tab Navigation --}}
  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="locations">Locations</a>
    <a class="item" data-tab="logistics">Logistics</a>
    <a class="item" data-tab="status">Status</a>
    <a class="item" data-tab="mtoe">MTOE</a>
    <a class="item" data-tab="assets">Assets</a>
    <a class="item" data-tab="finances">Finances</a>
  </nav>

  <section class="sheet-body">

    {{!-- ==================== LOCATIONS TAB ==================== --}}
    <div class="tab" data-tab="locations" data-group="primary">
      <div class="tab-content">

        <div class="pool-strip">
          {{#each crewPools}}
          <div class="pool-chip {{#if this.over}}over{{/if}}">
            <span class="pool-label">{{this.label}}</span>
            <span class="pool-count"><span class="pool-free">{{this.available}}</span> free / <span class="pool-assigned">{{this.assigned}}</span> assigned</span>
          </div>
          {{/each}}
          <span class="pool-hint">Totals on the Status tab</span>
        </div>

        <p class="drop-hint"><i class="fas fa-anchor"></i> Drag a Naval Ship or Installation actor here to add it as a location.</p>

        {{#each locations}}
        <div class="location-card {{#if this.expanded}}expanded{{else}}collapsed{{/if}}" data-loc-id="{{this.id}}">
          <div class="location-head">
            <span class="location-toggle" data-loc-id="{{this.id}}" title="Expand / collapse">
              <i class="fas {{#if this.expanded}}fa-chevron-down{{else}}fa-chevron-right{{/if}}"></i>
            </span>
            <img class="location-toggle" data-loc-id="{{this.id}}" src="{{this.img}}" width="40" height="40" />
            <div class="location-title location-toggle" data-loc-id="{{this.id}}">
              <span class="location-name">{{this.name}}</span>
              <span class="location-type">{{this.typeLabel}}{{#unless this.exists}} — actor deleted{{/unless}}</span>
            </div>
            <span class="loc-sum" title="Assigned crew / required"><i class="fas fa-users"></i> {{this.crewAssignedTotal}}/{{this.crewRequiredTotal}}</span>
            <span class="loc-sum" title="Current armor / max armor"><i class="fas fa-shield-halved"></i> {{this.armorValue}}/{{this.armorMax}}</span>
            <div class="location-status-field">
              <label>Status</label>
              <input type="text" class="location-status" data-loc-id="{{this.id}}" value="{{this.status}}" placeholder="e.g. On station" {{#unless ../editable}}disabled{{/unless}} />
            </div>
            {{#if ../editable}}
            <a class="location-remove" data-loc-id="{{this.id}}" title="Remove Location"><i class="fas fa-times"></i></a>
            {{/if}}
          </div>

          {{#if this.expanded}}
          <div class="location-body">
            <div class="dept-block-header">
              <span><i class="fas fa-sitemap"></i> Departments</span>
              <span class="dept-block-note">Defined on the vessel sheet · assign crew here</span>
            </div>

            {{#each this.departments}}
            <div class="dept-row {{#if this.understaffed}}understaffed{{/if}}">
              <div class="dept-row-top">
                <span class="dept-type-label">{{this.typeLabel}}</span>

                <span class="vet-badge vet-{{this.veterancy}}">{{this.veterancy}} ({{#if (gte this.vetMod 0)}}+{{/if}}{{this.vetMod}})</span>
                <div class="xp-track" title="{{this.xpInto}}/100 XP to next tier">
                  <div class="xp-fill" style="width:{{this.xpPct}}%"></div>
                </div>
                <input type="number" class="dept-xp xp-input" min="0" data-loc-id="{{../id}}" data-dept-id="{{this.id}}" value="{{this.xp}}" title="Total XP" {{#unless ../../editable}}disabled{{/unless}} />

                <span class="staff-badge {{#if this.staffWarn}}warn{{/if}}" title="{{this.penaltyLabel}}">{{this.staffPct}}%{{this.staffSuffix}}</span>
                <button type="button" class="dept-roll" data-loc-id="{{../id}}" data-dept-id="{{this.id}}"
                        title="{{#if this.canRoll}}Roll a department task{{else}}Below 50% staffing — cannot roll{{/if}}"
                        {{#unless this.canRoll}}disabled{{/unless}}><i class="fas fa-dice"></i></button>
              </div>

              <div class="dept-crew-grid">
                {{#each this.crew}}
                <div class="dept-crew-cell">
                  <span class="dept-crew-label">{{this.label}}</span>
                  <span class="dept-crew-inputs">
                    <input type="number" class="dept-assign" min="0"
                           data-loc-id="{{../../id}}" data-dept-id="{{../id}}" data-slot="{{this.slot}}"
                           value="{{this.assigned}}" title="Assigned" {{#unless ../../../editable}}disabled{{/unless}} />
                    <span class="dept-crew-sep">/</span>
                    <span class="dept-req-val" title="Required (set on vessel)">{{this.required}}</span>
                  </span>
                </div>
                {{/each}}
                <span class="dept-fill {{#if this.understaffed}}short{{/if}}">Staffed {{this.assignedTotal}}/{{this.reqTotal}}</span>
              </div>
            </div>
            {{/each}}
            {{#unless this.departments.length}}
            {{#if this.deptSupported}}
            <p class="empty-notice small">No departments defined on this vessel yet — add them on its actor sheet.</p>
            {{else}}
            <p class="empty-notice small">This location type doesn't define departments yet.</p>
            {{/if}}
            {{/unless}}
          </div>
          {{/if}}
        </div>
        {{/each}}

        {{#unless locations.length}}
        <p class="empty-notice">No locations. Drag a Naval Ship or Installation actor here.</p>
        {{/unless}}
      </div>
    </div>

    {{!-- ==================== LOGISTICS TAB ==================== --}}
    <div class="tab" data-tab="logistics" data-group="primary">
      <div class="tab-content">

        {{!-- Company-wide summary (read-only) --}}
        <div class="items-header logi-summary-head">
          <h3><i class="fas fa-boxes-stacked"></i> Total Supplies — all locations</h3>
          {{#if editable}}<button type="button" class="transfer-supplies"><i class="fas fa-right-left"></i> Transfer</button>{{/if}}
        </div>
        <div class="logi-summary">
          <div class="logi-sum-group">
            <span class="logi-sum-title">Ship</span>
            {{#each logiSummaryShip}}<span class="sum-chip">{{this.label}} <strong>{{this.value}}</strong></span>{{/each}}
          </div>
          {{#each logiSummaryGround}}
          <div class="logi-sum-group">
            <span class="logi-sum-title">{{this.label}}</span>
            {{#each this.fields}}<span class="sum-chip">{{this.label}} <strong>{{this.value}}</strong></span>{{/each}}
          </div>
          {{/each}}
          {{#if logiAmmoSummary.length}}
          <div class="logi-sum-group">
            <span class="logi-sum-title">Ammo</span>
            {{#each logiAmmoSummary}}<span class="sum-chip">{{this.name}} <strong>{{this.tons}}</strong></span>{{/each}}
          </div>
          {{/if}}
        </div>

        {{!-- Per-location cargo (expandable) --}}
        {{#each logiLocations}}
        <div class="logi-card {{#if this.expanded}}expanded{{else}}collapsed{{/if}}" data-loc-id="{{this.id}}">
          <div class="logi-card-head logi-toggle" data-loc-id="{{this.id}}">
            <i class="fas {{#if this.expanded}}fa-chevron-down{{else}}fa-chevron-right{{/if}}"></i>
            <img src="{{this.img}}" width="24" height="24" />
            <span class="location-name">{{this.name}}</span>
            <span class="location-type">{{this.typeLabel}}</span>
            <span class="logi-cap {{#if this.full}}full{{/if}}"><i class="fas fa-weight-hanging"></i> {{this.used}} / {{this.capacity}} t</span>
          </div>

          {{#if this.expanded}}
          <div class="logi-card-body">
            {{#if this.full}}<p class="logi-note warn">Cargo full — free space or add cargo bays on the vessel to store more.</p>{{/if}}

            <h4 class="category-title">Ship Supplies</h4>
            <div class="supply-grid">
              {{#each this.ship}}
              <div class="supply-cell">
                <label>{{this.label}}</label>
                <input type="number" min="0" class="cargo-ship" data-actor-id="{{../actorId}}" data-group="ship" data-key="{{this.key}}" value="{{this.value}}" {{#unless ../../editable}}disabled{{/unless}} />
              </div>
              {{/each}}
            </div>

            <div class="ammo-block">
              <div class="ammo-block-head">
                <span><i class="fas fa-box"></i> Ship Ammo</span>
                {{#if ../editable}}<button type="button" class="add-cargo-ammo" data-actor-id="{{this.actorId}}" data-group="shipAmmo"><i class="fas fa-plus"></i> Add</button>{{/if}}
              </div>
              {{#each this.shipAmmo}}
              <div class="ammo-row">
                <input type="text" class="cargo-ammo-field" data-actor-id="{{../actorId}}" data-group="shipAmmo" data-ammo-id="{{this.id}}" data-field="name" value="{{this.name}}" placeholder="Ammo type" {{#unless ../../editable}}disabled{{/unless}} />
                <input type="number" min="0" class="cargo-ammo-field" data-actor-id="{{../actorId}}" data-group="shipAmmo" data-ammo-id="{{this.id}}" data-field="value" value="{{this.value}}" placeholder="t" {{#unless ../../editable}}disabled{{/unless}} />
                {{#if ../../editable}}<a class="remove-cargo-ammo" data-actor-id="{{../actorId}}" data-group="shipAmmo" data-ammo-id="{{this.id}}" title="Remove"><i class="fas fa-times"></i></a>{{/if}}
              </div>
              {{/each}}
            </div>

            <h4 class="category-title">Ground Forces Supplies</h4>
            {{#each this.ground}}
            <div class="ground-group">
              <span class="ground-group-title">{{this.label}}</span>
              <div class="supply-grid">
                {{#each this.fields}}
                <div class="supply-cell">
                  <label>{{this.label}}</label>
                  <input type="number" min="0" class="cargo-ground" data-actor-id="{{../../actorId}}" data-group="ground" data-key="{{this.key}}" value="{{this.value}}" {{#unless ../../../editable}}disabled{{/unless}} />
                </div>
                {{/each}}
              </div>
            </div>
            {{/each}}

            <div class="ammo-block">
              <div class="ammo-block-head">
                <span><i class="fas fa-box"></i> Ground Ammo</span>
                {{#if ../editable}}<button type="button" class="add-cargo-ammo" data-actor-id="{{this.actorId}}" data-group="groundAmmo"><i class="fas fa-plus"></i> Add</button>{{/if}}
              </div>
              {{#each this.groundAmmo}}
              <div class="ammo-row wide">
                <input type="text" class="cargo-ammo-field" data-actor-id="{{../actorId}}" data-group="groundAmmo" data-ammo-id="{{this.id}}" data-field="name" value="{{this.name}}" placeholder="Ammo type" {{#unless ../../editable}}disabled{{/unless}} />
                <input type="text" class="cargo-ammo-field" data-actor-id="{{../actorId}}" data-group="groundAmmo" data-ammo-id="{{this.id}}" data-field="usedBy" value="{{this.usedBy}}" placeholder="Used by (unit)" {{#unless ../../editable}}disabled{{/unless}} />
                <input type="number" min="0" class="cargo-ammo-field" data-actor-id="{{../actorId}}" data-group="groundAmmo" data-ammo-id="{{this.id}}" data-field="value" value="{{this.value}}" placeholder="t" {{#unless ../../editable}}disabled{{/unless}} />
                {{#if ../../editable}}<a class="remove-cargo-ammo" data-actor-id="{{../actorId}}" data-group="groundAmmo" data-ammo-id="{{this.id}}" title="Remove"><i class="fas fa-times"></i></a>{{/if}}
              </div>
              {{/each}}
            </div>
          </div>
          {{/if}}
        </div>
        {{/each}}
        {{#unless hasLogiLocations}}
        <p class="empty-notice">No locations yet. Add ships/installations on the Locations tab — supplies live in their cargo bays.</p>
        {{/unless}}
      </div>
    </div>

    {{!-- ==================== STATUS TAB ==================== --}}
    <div class="tab" data-tab="status" data-group="primary">
      <div class="tab-content">
        <div class="status-section">
          <h3>Company Status</h3>
          <div class="status-overview">
            <div class="status-item"><label>Total Personnel</label><span>{{totalPersonnel}}</span></div>
            <div class="status-item"><label>Locations</label><span>{{locationCount}}</span></div>
            <div class="status-item"><label>MTOE Units</label><span>{{unitBoxCount}}</span></div>
            <div class="status-item"><label>Available Funds</label><span>{{numberFormat system.cbills}} C-Bills</span></div>
            <div class="status-item"><label>Monthly Salaries</label><span>{{numberFormat monthlyExpenses}} C-Bills</span></div>
          </div>

          {{!-- Personnel pool editor --}}
          <div class="pool-editor">
            <h3><i class="fas fa-users"></i> Personnel Pools</h3>
            <div class="pool-editor-group">
              <h4 class="category-title">Ship Crew</h4>
              <div class="pool-grid">
                {{#each crewPools}}
                <div class="pool-edit-cell {{#if this.over}}over{{/if}}">
                  <label>{{this.label}}</label>
                  <input type="number" min="0" name="system.personnel.{{this.key}}" value="{{this.total}}" {{#unless ../editable}}disabled{{/unless}} />
                  <span class="pool-sub"><span class="pool-assigned">{{this.assigned}}</span> assigned · <span class="pool-free">{{this.available}}</span> free · {{numberFormat this.salary}} C-Bills ea.</span>
                </div>
                {{/each}}
              </div>
            </div>
            <div class="pool-editor-group">
              <h4 class="category-title">Combat Troops</h4>
              <div class="pool-grid">
                {{#each troopPools}}
                <div class="pool-edit-cell {{#if this.over}}over{{/if}}">
                  <label>{{this.label}}</label>
                  <input type="number" min="0" name="system.personnel.{{this.key}}" value="{{this.total}}" {{#unless ../editable}}disabled{{/unless}} />
                  <span class="pool-sub"><span class="pool-assigned">{{this.assigned}}</span> assigned · <span class="pool-free">{{this.available}}</span> free · {{numberFormat this.salary}} C-Bills ea.</span>
                </div>
                {{/each}}
              </div>
            </div>
          </div>

          {{!-- Medical status framework --}}
          <div class="medical-section">
            <h3><i class="fas fa-kit-medical"></i> Medical</h3>
            <table class="medical-table">
              <thead>
                <tr>
                  <th class="med-type-col">Personnel Type</th>
                  {{#each medicalStatuses}}<th>{{this.label}}</th>{{/each}}
                </tr>
              </thead>
              <tbody>
                {{#each medicalRows}}
                <tr>
                  <td class="med-type-col">{{this.label}}</td>
                  {{#each this.cells}}
                  <td><input type="number" min="0" name="system.medical.{{../key}}.{{this.key}}" value="{{this.value}}" {{#unless ../../editable}}disabled{{/unless}} /></td>
                  {{/each}}
                </tr>
                {{/each}}
              </tbody>
              <tfoot>
                <tr class="med-total-row">
                  <td class="med-type-col">Total</td>
                  {{#each medicalTotals}}<td>{{this.value}}</td>{{/each}}
                </tr>
              </tfoot>
            </table>
          </div>

          <div class="company-notes">
            <h3>Notes</h3>
            <div class="editor-container">
              {{#if editable}}
              <prose-mirror name="system.biography" data-document-uuid="{{actor.uuid}}" value="{{system.biography}}" collaborate="false" toggled="true">{{{enrichedBiography}}}</prose-mirror>
              {{else}}{{{enrichedBiography}}}{{/if}}
            </div>
          </div>
        </div>
      </div>
    </div>

    {{!-- ==================== MTOE TAB ==================== --}}
    <div class="tab" data-tab="mtoe" data-group="primary">
      <div class="tab-content">
        <h3>Modified Table of Organization &amp; Equipment</h3>

        <div class="pool-strip">
          {{#each troopPools}}
          <div class="pool-chip {{#if this.over}}over{{/if}}">
            <span class="pool-label">{{this.label}}</span>
            <span class="pool-count"><span class="pool-free">{{this.available}}</span> free / <span class="pool-assigned">{{this.assigned}}</span> assigned</span>
          </div>
          {{/each}}
          <span class="pool-hint">Totals on the Status tab</span>
        </div>

        {{#if editable}}
        <div class="mtoe-controls">
          <button type="button" class="add-mtoe-box"><i class="fas fa-plus"></i> Add Unit Box</button>
        </div>
        {{/if}}

        <div class="mtoe-boxes">
        {{#each mtoe}}
        <div class="mtoe-box" data-box-id="{{this.id}}">
          <div class="mtoe-box-head">
            <input type="text" class="mtoe-box-name" data-box-id="{{this.id}}" value="{{this.name}}" placeholder="Unit name" {{#unless ../editable}}disabled{{/unless}} />
            {{#if ../editable}}
            <a class="remove-mtoe-box" data-box-id="{{this.id}}" title="Delete Unit Box"><i class="fas fa-trash"></i></a>
            {{/if}}
          </div>

          <div class="mtoe-box-controls">
            <label class="ctl">Status
              <select class="mtoe-box-status" data-box-id="{{this.id}}" {{#unless ../editable}}disabled{{/unless}}>
                {{#each ../unitStatuses}}
                <option value="{{this}}" {{#if (eq this ../status)}}selected{{/if}}>{{this}}</option>
                {{/each}}
              </select>
            </label>
            <label class="ctl">Location
              <select class="mtoe-location" data-box-id="{{this.id}}" {{#unless ../editable}}disabled{{/unless}}>
                <option value="">— Unassigned —</option>
                {{#each ../mtoeLocationOptions}}
                <option value="{{this.actorId}}" {{#if (eq this.actorId ../locationId)}}selected{{/if}}>{{this.name}}</option>
                {{/each}}
              </select>
            </label>
          </div>
          {{#if this.locationName}}<div class="mtoe-location-tag"><i class="fas fa-location-dot"></i> Based at {{this.locationName}}</div>{{/if}}
          {{#if this.locationMissing}}<div class="mtoe-warning"><i class="fas fa-triangle-exclamation"></i> Assigned location actor is missing.</div>{{/if}}

          <div class="mtoe-box-vet">
            <span class="vet-badge vet-{{this.veterancy}}">{{this.veterancy}} ({{#if (gte this.vetMod 0)}}+{{/if}}{{this.vetMod}})</span>
            <div class="xp-track" title="{{this.xpInto}}/100 XP to next tier"><div class="xp-fill" style="width:{{this.xpPct}}%"></div></div>
            <input type="number" class="mtoe-xp xp-input" min="0" data-box-id="{{this.id}}" value="{{this.xp}}" title="Total XP" {{#unless ../editable}}disabled{{/unless}} />
            <button type="button" class="mtoe-roll" data-box-id="{{this.id}}" title="Roll a unit task"><i class="fas fa-dice"></i></button>
          </div>

          {{!-- Roster grouped by combat type; crew paired with matching vehicle --}}
          <div class="mtoe-roster">
            {{#each this.groups}}
            <div class="roster-group">
              <div class="roster-head">
                <span>{{this.troopLabel}} ({{this.personnelCount}})</span>
                <span>{{#if this.hasVehicle}}{{this.vehicleLabel}} ({{this.vehicleCount}}){{else}}—{{/if}}</span>
              </div>
              {{#if this.mismatch}}<div class="mtoe-warning small"><i class="fas fa-triangle-exclamation"></i> {{this.mismatch}}</div>{{/if}}
              {{#each this.rows}}
              <div class="roster-row">
                <div class="roster-person">
                  {{#if this.person}}
                  <span class="rp-name">{{this.person.typeLabel}}</span>
                  <select class="person-status status-{{this.person.status}}" data-box-id="{{../../id}}" data-person-id="{{this.person.id}}" {{#unless ../../../editable}}disabled{{/unless}}>
                    {{#each ../../../personStatuses}}<option value="{{this}}" {{#if (eq this ../person.status)}}selected{{/if}}>{{this}}</option>{{/each}}
                  </select>
                  {{#if ../../../editable}}<a class="remove-personnel" data-box-id="{{../../id}}" data-person-id="{{this.person.id}}" title="Remove"><i class="fas fa-times"></i></a>{{/if}}
                  {{else}}<span class="rp-empty">—</span>{{/if}}
                </div>
                <div class="roster-vehicle">
                  {{#if this.vehicle}}
                  <a class="mtoe-unit-open {{#unless this.vehicle.exists}}missing{{/unless}}" data-actor-id="{{this.vehicle.actorId}}" title="Open sheet">
                    <img src="{{this.vehicle.img}}" width="18" height="18" />{{this.vehicle.name}}
                  </a>
                  <select class="vehicle-status vstatus-{{this.vehicle.status}}" data-box-id="{{../../id}}" data-actor-id="{{this.vehicle.actorId}}" {{#unless ../../../editable}}disabled{{/unless}}>
                    {{#each ../../../vehicleStatuses}}<option value="{{this}}" {{#if (eq this ../vehicle.status)}}selected{{/if}}>{{this}}</option>{{/each}}
                  </select>
                  {{#if ../../../editable}}<a class="mtoe-unit-remove" data-box-id="{{../../id}}" data-actor-id="{{this.vehicle.actorId}}" title="Remove"><i class="fas fa-times"></i></a>{{/if}}
                  {{else}}<span class="rp-empty">—</span>{{/if}}
                </div>
              </div>
              {{/each}}
            </div>
            {{/each}}
            {{#unless this.hasRoster}}<p class="empty-notice small">No personnel or vehicles yet.</p>{{/unless}}
          </div>

          {{#if ../editable}}
          <div class="mtoe-box-actions">
            <select class="add-personnel" data-box-id="{{this.id}}" title="Add a crew member">
              <option value="">+ Add crew…</option>
              {{#each ../troopTypes}}<option value="{{this.key}}">{{this.label}}</option>{{/each}}
            </select>
            <span class="drop-zone small">Drag Mech / Vehicle / Fighter / Battle Armor actors here</span>
          </div>
          {{/if}}
        </div>
        {{/each}}
        </div>

        {{#unless mtoe.length}}
        <p class="empty-notice">No unit boxes. Click "Add Unit Box", pick a personnel type, then add personnel and drag matching vehicles onto it.</p>
        {{/unless}}
      </div>
    </div>

    {{!-- ==================== ASSETS TAB ==================== --}}
    <div class="tab" data-tab="assets" data-group="primary">
      <div class="tab-content assets-tab">
        <h3>Company Assets</h3>

        {{#if companyAssets.weapon.length}}
        <div class="asset-category">
          <h4 class="category-title">Weapons</h4>
          <div class="asset-grid asset-header">
            <div class="ac-name">Name</div><div>Type</div><div>AP</div><div>BD</div><div class="ac-qty">Qty</div><div class="ac-cost">Cost</div><div class="ac-ctrl">Controls</div>
          </div>
          {{#each companyAssets.weapon}}
          <div class="asset-grid asset-row" data-item-id="{{this._id}}">
            <div class="ac-name">{{this.name}}</div>
            <div>{{this.system.weaponType}}</div>
            <div>{{this.system.ap}}{{this.system.apFactor}}</div>
            <div>{{this.system.bd}}{{this.system.bdFactor}}</div>
