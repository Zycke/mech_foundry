{
  "id": "mech-foundry",
  "title": "Mech Foundry",
  "description": "A mech-based TTRPG system inspired by A Time of War and the BattleTech universe.",
  "version": "0.5.9",
  "compatibility": {
    "minimum": "14",
    "verified": "14"
  },
  "authors": [
    {
      "name": "Zycke",
      "url": "https://github.com/Zycke"
    }
  ],
  "esmodules": ["module/mech-foundry.mjs"],
  "styles": ["css/mech-foundry.css"],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "packs": [
    {
      "name": "life-modules",
      "label": "Life Modules",
      "path": "packs/life-modules",
      "type": "Item",
      "system": "mech-foundry",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "skills",
      "label": "Skills (Reference)",
      "path": "packs/skills",
      "type": "Item",
      "system": "mech-foundry",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "traits",
      "label": "Traits (Reference)",
      "path": "packs/traits",
      "type": "Item",
      "system": "mech-foundry",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    }
  ],
  "packFolders": [
    {
      "name": "Character Creation",
      "sorting": "m",
      "packs": ["life-modules", "skills", "traits"]
    }
  ],
  "grid": {
    "distance": 1,
    "units": "m"
  },
  "primaryTokenAttribute": "damage",
  "secondaryTokenAttribute": "fatigue",
  "socket": true,
  "url": "https://github.com/Zycke/mech_foundry",
  "manifest": "https://raw.githubusercontent.com/Zycke/mech_foundry/main/system.json",
  "download": "https://github.com/Zycke/mech_foundry/archive/refs/heads/main.zip"
}
